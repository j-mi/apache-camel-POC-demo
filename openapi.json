{
  "openapi": "3.0.3",
  "info": {
    "title": "Camel Weather Location POC",
    "version": "1.0.0",
    "description": "Apache Camel integration: POST /process returns the current weather plus the geocoded lat/lon for a given (name, city). /users is a tiny mock DB."
  },
  "servers": [
    { "url": "/", "description": "Same origin as the Swagger UI page" }
  ],
  "tags": [
    { "name": "weather",  "description": "Weather lookup" },
    { "name": "users",    "description": "Mock user registry" },
    { "name": "platform", "description": "Health, OpenAPI" }
  ],
  "paths": {
    "/process": {
      "post": {
        "tags": ["weather"],
        "summary": "Look up current weather + coordinates for a (name, city).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WeatherRequest" },
              "example": { "name": "Teemu", "city": "Turku" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Weather + coordinates",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WeatherResponse" } } }
          },
          "400": {
            "description": "Missing name or city",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "404": {
            "description": "User not registered (only when JSONMOCKDB=true)",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/users": {
      "post": {
        "tags": ["users"],
        "summary": "Register a (name, city).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/User" },
              "example": { "name": "Teemu", "city": "Turku" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Saved",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserSaved" } } }
          },
          "400": {
            "description": "Missing name or city",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "get": {
        "tags": ["users"],
        "summary": "List registered users.",
        "responses": {
          "200": {
            "description": "JSON array of users",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/User" } },
                "example": [ { "name": "Teemu", "city": "Turku" } ]
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["platform"],
        "summary": "Liveness probe.",
        "responses": {
          "200": {
            "description": "App is up",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string", "example": "UP" } } } } }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "WeatherRequest": {
        "type": "object",
        "required": ["name", "city"],
        "properties": {
          "name": { "type": "string", "example": "Teemu" },
          "city": { "type": "string", "example": "Turku" }
        }
      },
      "WeatherResponse": {
        "type": "object",
        "properties": {
          "name":               { "type": "string",  "example": "Teemu" },
          "city":               { "type": "string",  "example": "Turku" },
          "latitude":           { "type": "number",  "example": 60.4518 },
          "longitude":          { "type": "number",  "example": 22.2666 },
          "currentTemperature": { "type": "number",  "example": 19.1 },
          "time":               { "type": "string",  "example": "2026-05-18T18:00" },
          "requestId":          { "type": "string",  "example": "6C1299F2B41F3E7-0000000000000010" },
          "timestamp":          { "type": "string",  "example": "2026-05-18T18:05:18.678Z" }
        }
      },
      "User": {
        "type": "object",
        "required": ["name", "city"],
        "properties": {
          "name": { "type": "string", "example": "Teemu" },
          "city": { "type": "string", "example": "Turku" }
        }
      },
      "UserSaved": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "saved" },
          "name":   { "type": "string", "example": "Teemu" },
          "city":   { "type": "string", "example": "Turku" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error":     { "type": "string" },
          "hint":      { "type": "string" },
          "name":      { "type": "string" },
          "city":      { "type": "string" },
          "requestId": { "type": "string" }
        }
      }
    }
  }
}
